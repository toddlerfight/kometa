# Copy to .env (gitignored) and fill in. Never commit real values — this repo is public.

# Komga
KOMGA_URL=http://your-nas-host:8585
KOMGA_USER=your@email.com
KOMGA_PASS=yourpassword
KOMGA_LIBRARY_ID=yourkomgalibraryid

# Metadata sources
METRON_USER=yourusername
METRON_PASS=yourpassword
CV_API_KEY=yourcomicvinekey

# Scheduler
KOMETA_SYNC_HOURS=5,12,17

# Deploy target (used by deploy.sh)
NAS_HOST=your-nas-host
NAS_USER=yournasuser
NAS_PORT=22
NAS_KEY=~/.ssh/your_key
