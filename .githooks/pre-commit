#!/usr/bin/env bash
# Stop private details reaching a PUBLIC repo.
#
# On 2026-07-20 this repo was found public with the NAS IP, SSH port, username,
# tailnet hostname and Komga library ID committed in plain sight — plus an
# INSTRUCTIONS.md line cheerfully asserting the repo was private. Cleaning it
# took a full history rewrite across 305 commits, a force-push, and a merged PR
# ref that GitHub will not let anyone delete, ever.
#
# The first cut of this hook then committed those same literals into its own
# pattern list, on the public repo, which is a very stupid way to leak. Hence
# the split below: patterns here are GENERIC and safe to publish. Anything
# site-specific lives in .githooks/patterns.local, which is gitignored.
# Never put a real hostname, ID or username in this file.
#
# Bypass with --no-verify if you genuinely must. Think first.
set -uo pipefail

HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"

STAGED="$(git diff --cached --name-only --diff-filter=ACM)"
[ -z "$STAGED" ] && exit 0

# label|regex — extended regex, case-insensitive. Generic by construction:
# these describe the SHAPE of a secret, not its value.
CHECKS=(
  "private LAN IP|(^|[^0-9])(192\.168\.[0-9]{1,3}\.[0-9]{1,3}|10\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}|172\.(1[6-9]|2[0-9]|3[01])\.[0-9]{1,3}\.[0-9]{1,3})"
  "tailscale hostname|[a-z0-9-]+\.ts\.net|(^|[^0-9])100\.(6[4-9]|[7-9][0-9]|1[0-1][0-9]|12[0-7])\.[0-9]{1,3}\.[0-9]{1,3}"
  "ssh with explicit key/port|ssh[[:space:]]+.*-i[[:space:]]+[~/][^[:space:]]*|ssh[[:space:]]+-p[[:space:]]+[0-9]{2,5}[[:space:]]+[^[:space:]]*@"
  "private key block|BEGIN[[:space:]]+(OPENSSH|RSA|EC|DSA|PGP)[[:space:]]+PRIVATE[[:space:]]+KEY"
  "iCloud alias|[a-z]+[._][a-z]+[._][a-z0-9]+@icloud\.com"
  "bare 32-hex key|[^a-f0-9][a-f0-9]{32}[^a-f0-9]"
  "inline credential|(password|passwd|api_?key|apikey|secret|token)[\"']?[[:space:]]*[:=][[:space:]]*[\"'][^\"'\$][^\"']{7,}[\"']"
)

# Site-specific literals (real hostnames, IDs, usernames) go here. Gitignored,
# so they never reach the public repo. Format: one `label|regex` per line,
# blank lines and #comments ignored. See patterns.local.example.
LOCAL="$HOOK_DIR/patterns.local"
if [ -f "$LOCAL" ]; then
  while IFS= read -r line; do
    case "$line" in ''|'#'*) continue ;; esac
    CHECKS+=("$line")
  done < "$LOCAL"
fi

FOUND=0

for file in $STAGED; do
  # Skip the guard itself — its patterns would trip its own checks.
  case "$file" in
    .githooks/*) continue ;;
  esac

  # Only inspect ADDED lines; existing history is already dealt with.
  added="$(git diff --cached -U0 -- "$file" | grep '^+' | grep -v '^+++')"
  [ -z "$added" ] && continue

  for check in "${CHECKS[@]}"; do
    label="${check%%|*}"
    pattern="${check#*|}"
    if hits="$(printf '%s\n' "$added" | grep -inE "$pattern" | head -3)"; [ -n "$hits" ]; then
      if [ "$FOUND" -eq 0 ]; then
        echo ""
        echo "  ✖ BLOCKED — private details in staged changes."
        echo "    This repo is PUBLIC. These values belong in .env, not in git."
        echo ""
      fi
      FOUND=1
      echo "  $file — $label"
      printf '%s\n' "$hits" | sed 's/^/      /'
    fi
  done
done

if [ "$FOUND" -eq 1 ]; then
  echo ""
  echo "  Fix: move the value into .env (gitignored) and reference it as a"
  echo "  variable, or replace it with a placeholder. See .env.example."
  echo ""
  echo "  Override (rarely right): git commit --no-verify"
  echo ""
  exit 1
fi

exit 0
